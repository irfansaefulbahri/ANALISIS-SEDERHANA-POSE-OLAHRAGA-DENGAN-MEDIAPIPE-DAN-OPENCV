import cv2
import mediapipe as mp
import numpy as np

# import yang benar untuk versi terbaru
mp_drawing = mp.solutions.drawing_utils
mp_pose = mp.solutions.pose

def calculate_angle(a, b, c):
    a = np.array(a) # Titik pangkal (contoh: Bahu)
    b = np.array(b) # Titik tengah/sendi (contoh: Siku)
    c = np.array(c) # Titik ujung (contoh: Pergelangan tangan)
    
    # Menghitung radian dan mengonversinya ke derajat
    radians = np.arctan2(c[1]-b[1], c[0]-b[0]) - np.arctan2(a[1]-b[1], a[0]-b[0])
    angle = np.abs(radians*180.0/np.pi)
    
    # Memastikan sudut tidak lebih dari 180 derajat
    if angle > 180.0:
        angle = 360 - angle
        
    return angle

# Mengakses Webcam (0 adalah ID default kamera bawaan)
cap = cv2.VideoCapture(0)

# Variabel untuk menghitung repetisi dan status gerakan (state machine)
counter = 0 
stage = None

# Mengatur threshold deteksi MediaPipe
with mp_pose.Pose(min_detection_confidence=0.5, min_tracking_confidence=0.5) as pose:
    while cap.isOpened():
        ret, frame = cap.read()
        if not ret:
            break
            
        # Recolor gambar dari BGR (bawaan OpenCV) ke RGB (kebutuhan MediaPipe)
        image = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        image.flags.writeable = False
      
        # Ekstraksi Landmarks (Titik Sendi)
        results = pose.process(image)
    
        # Recolor kembali gambar ke BGR untuk ditampilkan di layar
        image.flags.writeable = True
        image = cv2.cvtColor(image, cv2.COLOR_RGB2BGR)
        
        # Ekstraksi koordinat jika pose terdeteksi
        try:
            landmarks = results.pose_landmarks.landmark
            
            # Mengambil koordinat spesifik: Bahu, Siku, Pergelangan (Kiri)
            shoulder = [landmarks[mp_pose.PoseLandmark.LEFT_SHOULDER.value].x, landmarks[mp_pose.PoseLandmark.LEFT_SHOULDER.value].y]
            elbow = [landmarks[mp_pose.PoseLandmark.LEFT_ELBOW.value].x, landmarks[mp_pose.PoseLandmark.LEFT_ELBOW.value].y]
            wrist = [landmarks[mp_pose.PoseLandmark.LEFT_WRIST.value].x, landmarks[mp_pose.PoseLandmark.LEFT_WRIST.value].y]
            
            # Hitung sudut
            angle = calculate_angle(shoulder, elbow, wrist)
            
            # Visualisasi angka sudut tepat di titik siku
            cv2.putText(image, str(int(angle)), 
                           tuple(np.multiply(elbow, [640, 480]).astype(int)), 
                           cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 255, 255), 2, cv2.LINE_AA)
            
            # Logika Penghitung Repetisi (State Machine)
            if angle > 160: # Lengan terentang lurus
                stage = "down"
            if angle < 30 and stage == 'down': # Lengan ditekuk penuh
                stage = "up"
                counter += 1
                print(f"Repetisi: {counter}")
                       
        except:
            pass
        
        # UI/Antarmuka Sederhana di Layar
        cv2.rectangle(image, (0,0), (225,73), (245,117,16), -1)
        
        # Teks Repetisi
        cv2.putText(image, 'REPS', (15,12), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,0,0), 1, cv2.LINE_AA)
        cv2.putText(image, str(counter), (10,60), cv2.FONT_HERSHEY_SIMPLEX, 2, (255,255,255), 2, cv2.LINE_AA)
        
        # Teks Status Gerakan
        cv2.putText(image, 'STAGE', (65,12), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,0,0), 1, cv2.LINE_AA)
        cv2.putText(image, stage, (60,60), cv2.FONT_HERSHEY_SIMPLEX, 2, (255,255,255), 2, cv2.LINE_AA)
        
        # Render Skeleton MediaPipe ke layar
        mp_drawing.draw_landmarks(image, results.pose_landmarks, mp_pose.POSE_CONNECTIONS,
                                mp_drawing.DrawingSpec(color=(245,117,66), thickness=2, circle_radius=2), 
                                mp_drawing.DrawingSpec(color=(245,66,230), thickness=2, circle_radius=2) 
                                 )               
        
        # Menampilkan output
        cv2.imshow('Analisis Pose Olahraga', image)

        # Tekan 'q' untuk keluar dari program
        if cv2.waitKey(10) & 0xFF == ord('q'):
            break

    cap.release()
    cv2.destroyAllWindows()
